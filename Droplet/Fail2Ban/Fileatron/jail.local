[DEFAULT]
# -----------------------------------------------
# Global allowlist - these IPs will NEVER be banned
# Add your known SFTP clients, monitoring systems, VPN exits, etc.
# Supports single IPs, CIDR ranges, and DNS names
# -----------------------------------------------
ignoreip = 127.0.0.1/8 ::1
           45.10.101.131       
           104.250.186.148     

# Ban duration - start with 1 hour, increase if noise persists
bantime  = 1h

# Time window in which maxretry must occur
findtime = 10m

# Number of failures before banning
maxretry = 5

# Increase ban time for repeat offenders (requires fail2ban >= 0.11)
bantime.increment   = true
bantime.multiplier  = 2        
bantime.maxtime     = 1w       

# How fail2ban communicates with the firewall
# use 'iptables-multiport' if not using ufw
banaction = ufw                

[sshd]
enabled  = true
port     = ssh
logpath  = %(sshd_log)s
backend  = systemd             

# Tighter settings for SSH specifically
maxretry = 3                   
findtime = 5m
bantime  = 2h